<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <title>BookStore</title>
    </head>

    <body>
        <header><h1>Form</h1></header>

        <p><a href="/form">Click for Form</a></p>

            {{range .Books}}
            <article>
                <h2>{{.Title}}</h2>
                <div>{{.Author}}</div>
                <p>{{.Description}}</p>
                <time datetime="{{.CreatedAt}}">{{.CreatedAt}}</time>
            </article>
            {{end}}

        <footer>
            Powered by <a href="https://golang.org">Go</a>
        </footer>
    </body>
</html>